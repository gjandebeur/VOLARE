## VOLARE Pairwise Regression Template
### Section 1 — Parameters & Predictor Definitions
```{r setup}
library(tidyverse)
library(jsonlite)
library(readxl)

# ── PATHS (CHANGE THESE) ──
dataPath        <- "path/to/your_data.xlsx"
outputPath      <- "path/to/regressionModels.csv"
jsonOut         <- "path/to/output_forVolare.json"

# Optional: CpG methylation data
# betaPath        <- "path/to/beta_matrix.rds"
# sampleSheetPath <- "path/to/sample_sheet.csv"

pThreshold <- 0.05

# ── PREDICTOR DOMAINS ──
# Define column name vectors for each domain in your dataset.
# Add/remove domains as needed.
# for example,
# domain1Cols = grouping (CpG, diet, etc)
# each var1,var2 = the individual CpG or diet marker (protein intake, cg00000000, etc)

domain1Cols <- c("var1", "var2", "var3")
domain2Cols <- c("var4", "var5", "var6")
domain3Cols <- c("var7", "var8", "var9")

# Outcomes — column names of the raw outcome measures at each timepoint.
# The script computes change scores automatically (timepoint2 - timepoint1).
outcomeSources <- c("outcome1", "outcome2")
outcomeCols    <- paste0(outcomeSources, "_change")

predictorCols <- c(domain1Cols, domain2Cols, domain3Cols)

# VOLARE domain colors (one hex color per domain)
myColors <- c("#fb8072", "#80b1d3", "#f9a8d4", "#b3de69")

myAssays <- list(
  "Outcome_"  = list("#fb8072"),
  "Domain1_"  = list("#80b1d3"),
  "Domain2_"  = list("#f9a8d4"),
  "Domain3_"  = list("#b3de69")
)
```

