### Section 6 — VOLARE JSON Assembly

For each significant association: extracts slope and per-group intercepts,
computes mPlot line endpoints, calculates DFFITS influence, and builds
the JSON structure VOLARE expects.
```{r json-assembly}
if (nrow(bos) == 0) stop("No associations survived filtering — relax pThreshold.")

# Domain prefixes for VOLARE node coloring
prefix_map <- c(
  setNames(paste0("Outcome_", outcomeCols), outcomeCols),
  setNames(paste0("Domain1_", domain1Cols), domain1Cols),
  setNames(paste0("Domain2_", domain2Cols), domain2Cols),
  setNames(paste0("Domain3_", domain3Cols), domain3Cols)
  # Add CpG if used:
  # setNames(paste0("CpG_", cpgCols), cpgCols)
)

modelDat_v <- modelDat
colnames(modelDat_v) <- ifelse(
  colnames(modelDat_v) %in% names(prefix_map),
  prefix_map[colnames(modelDat_v)],
  colnames(modelDat_v)
)

bos$ana1 <- ifelse(bos$ana1 %in% names(prefix_map), prefix_map[bos$ana1], bos$ana1)
bos$ana2 <- ifelse(bos$ana2 %in% names(prefix_map), prefix_map[bos$ana2], bos$ana2)

n      <- nrow(modelDat_v)
cohort <- levels(modelDat_v$Cohort)
nCo    <- length(cohort)

# Initialize collectors
mySummary <- data.frame(key = NULL, Assays = NULL, Analyte1 = NULL, Analyte2 = NULL,
                        Corr = NULL, pCorr = NULL, estEff = NULL, maxInfluence = NULL)
mPlot    <- NULL
myDetail <- modelDat_v[, c("record_id", "Cohort")]

for (myRow in 1:nrow(bos)) {
  yAna <- as.character(bos$ana1[myRow])
  xAna <- as.character(bos$ana2[myRow])

  fitDat <- modelDat_v[complete.cases(modelDat_v[, c(yAna, xAna, "Cohort")]), ]

  if (!(yAna %in% colnames(myDetail))) myDetail <- cbind(myDetail, modelDat_v[yAna])
  if (!(xAna %in% colnames(myDetail))) myDetail <- cbind(myDetail, modelDat_v[xAna])

  m <- lm(as.formula(paste(yAna, "~", xAna, "+ age + sex + Cohort")), data = fitDat)

  # DFFITS influence
  infl_raw  <- abs(dffits(m))
  infl_full <- rep(NA_real_, nrow(modelDat_v))
  infl_full[as.integer(rownames(fitDat))] <- infl_raw
  myDetail  <- cbind(myDetail, infl_full)
  colnames(myDetail)[ncol(myDetail)] <- paste0("infl_", myRow)
  dffitsMax <- max(infl_raw)

  myCorr   <- cor(modelDat_v[[xAna]], modelDat_v[[yAna]], use = "complete.obs")
  myEstEff <- as.numeric(coef(m)[xAna])

  yDomain      <- sub("_.*", "", yAna)
  xDomain      <- sub("_.*", "", xAna)
  myAssayLabel <- paste0(yDomain, ".", xDomain)

  # ── mPlot line endpoints ──
  # Same slope, per-group intercepts (Cohort is covariate, not interaction)
  coefs <- coef(m)
  i1 <- unname(coefs["(Intercept)"])
  s  <- unname(coefs[xAna])

  # Build intercept vector for all cohort levels
  # Reference level gets base intercept; others get base + offset
  intercepts <- i1
  for (k in 2:nCo) {
    coefName <- paste0("Cohort", cohort[k])
    intercepts <- c(intercepts, i1 + unname(coefs[coefName]))
  }

  ra <- tapply(fitDat[[xAna]], fitDat$Cohort, range, na.rm = TRUE)

  myPoints <- NULL
  for (li in seq_along(ra)) {
    xMin_l <- ra[[li]][1]
    xMax_l <- ra[[li]][2]
    y1     <- s * xMin_l + intercepts[li]
    y2     <- s * xMax_l + intercepts[li]
    myPoints <- c(myPoints, xMin_l, y1, xMax_l, y2)
  }

  xMin <- min(modelDat_v[[xAna]], na.rm = TRUE)
  xMax <- max(modelDat_v[[xAna]], na.rm = TRUE)
  yMin <- min(modelDat_v[[yAna]], na.rm = TRUE)
  yMax <- max(modelDat_v[[yAna]], na.rm = TRUE)
  myPoints <- c(myPoints, xMin, yMin, xMax, yMax)

  thisRow <- data.frame(matrix(myPoints, nrow = 1))
  mPlot   <- rbind(mPlot, thisRow)

  mySummary <- rbind(mySummary, data.frame(
    key = myRow, Assays = myAssayLabel,
    Analyte1 = yAna, Analyte2 = xAna,
    Corr = round(myCorr, 3), pCorr = bos[myRow, "obsP"],
    estEff = myEstEff, maxInfluence = dffitsMax,
    row.names = NULL
  ))
}

mySummary$mPlot <- mPlot

myStatement <- sprintf(
  "Baseline predictors vs. longitudinal outcomes. N=%i, %i associations at p < %.2f. Cohort included as covariate. estEff = change in outcome per unit increase in predictor.",
  n, nrow(bos), pThreshold
)

cohort_viz <- as.list(cohort)

myConfiguration <- list(
  assayAware     = list("true"),
  assays         = myAssays,
  influenceAware = list("true"),
  cohort         = cohort_viz,
  colors         = myColors,
  statement      = list(myStatement)
)

myObject <- list(
  configuration = myConfiguration,
  statement     = myStatement,
  config        = cohort_viz,
  colors        = myColors,
  summary       = mySummary,
  detail        = myDetail
)

oJ <- toJSON(myObject, pretty = TRUE, dataframe = "columns", digits = 3)
write(oJ, jsonOut)

cat("JSON written to:", jsonOut, "\n")
cat("Associations:", nrow(bos), "\n")
```
