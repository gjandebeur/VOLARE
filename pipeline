### Section 4 — Pairwise Cross-Domain Regressions
```{r regressions}
write(paste("ana1", "ana2", "obsF", "obsP", sep = ","), outputPath, append = FALSE)

crossDomainPairs <- list(
  list(yVars = outcomeCols, xVars = domain1Cols),
  list(yVars = outcomeCols, xVars = domain2Cols),
  list(yVars = outcomeCols, xVars = domain3Cols)
  # Add more pairs as needed, e.g.:
  # list(yVars = outcomeCols, xVars = cpgCols)
)

for (pair in crossDomainPairs) {
  for (yCol in pair$yVars) {
    for (xCol in pair$xVars) {
      loopDat <- modelDat[complete.cases(modelDat[, c(yCol, xCol, "age", "sex", "Cohort")]), ]
      if (nrow(loopDat) < 10) next
      m    <- lm(as.formula(paste(yCol, "~", xCol, "+ age + sex + Cohort")), data = loopDat)
      mRed <- lm(as.formula(paste(yCol, "~ age + sex + Cohort")),            data = loopDat)
      a    <- anova(m, mRed)
      write(paste(yCol, xCol, a$F[2], a$"Pr(>F)"[2], sep = ","),
            outputPath, append = TRUE)
    }
  }
}
```

