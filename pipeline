### Section 2 — CpG Data Preparation (Optional)

Skip this section if you don't have methylation data. If you do, provide a
probe × sample beta matrix (.rds) and a sample sheet mapping array barcodes
to subject IDs.
```{r cpg-prep, eval=FALSE}
beta  <- readRDS(betaPath)
sheet <- read.csv(sampleSheetPath, skip = 7, header = TRUE)

sheet$idat_key <- paste0(sheet$Sentrix_ID, "_", sheet$Sentrix_Position)

# Filter to baseline samples — adjust the grep pattern to match your naming
sheet_bl <- sheet[grepl("-BL", sheet$Sample_Name), ]
sheet_bl$record_id <- as.numeric(gsub(".*-(\\d+)-.*", "\\1", sheet_bl$Sample_Name))

lookup <- sheet_bl[, c("idat_key", "record_id")]

beta_t          <- as.data.frame(t(beta))
beta_t$idat_key <- rownames(beta_t)

cpg_wide          <- merge(lookup, beta_t, by = "idat_key")
cpg_wide$idat_key <- NULL
```

---

### Section 3 — Load Data, Compute Deltas, Build Analytic Dataset

Expects a longitudinal dataset with a timepoint column. Pulls baseline
predictor values and computes outcome change scores (timepoint2 − timepoint1).
```{r load-data}
keyCols <- c("record_id", "Week", "age", "sex", outcomeSources, predictorCols)

# Group assignment (e.g., treatment arm, site, condition)
cohortMap <- read_excel(dataPath, sheet = "Covariates") %>%
  select(record_id, Intervention) %>%
  mutate(record_id = as.character(record_id),
         Cohort    = as.factor(Intervention)) %>%
  select(record_id, Cohort)

# Load baseline and follow-up rows
dataIn <- read_excel(
  path      = dataPath,
  sheet     = "Longitudinal",
  col_types = "text"
) %>%
  select(all_of(keyCols)) %>%
  mutate(
    Week = as.integer(Week),
    across(-record_id, as.numeric)
  ) %>%
  filter(Week %in% c(0, 26))  # adjust timepoints to your design

# Compute change scores
delta <- dataIn %>%
  select(record_id, Week, all_of(outcomeSources)) %>%
  pivot_longer(cols = all_of(outcomeSources), names_to = "measure", values_to = "value") %>%
  pivot_wider(names_from = Week, values_from = value, names_prefix = "wk") %>%
  filter(!is.na(wk0) & !is.na(wk26)) %>%
  mutate(change = wk26 - wk0) %>%
  select(record_id, measure, change) %>%
  pivot_wider(names_from = measure, values_from = change,
              names_glue = "{measure}_change")

# Assemble one row per participant
modelDat <- dataIn %>%
  filter(Week == 0) %>%
  inner_join(delta, by = "record_id") %>%
  inner_join(cohortMap, by = "record_id") %>%
  select(record_id, Cohort, age, sex,
         all_of(outcomeCols),
         all_of(predictorCols))

# Optional: merge CpG data
# cpg_wide$record_id <- as.character(cpg_wide$record_id)
# modelDat$record_id <- as.character(modelDat$record_id)
# modelDat <- left_join(modelDat, cpg_wide, by = "record_id")
# cpgCols <- grep("^cg", colnames(modelDat), value = TRUE)
# predictorCols <- c(predictorCols, cpgCols)

cat("Analytic N:", nrow(modelDat), "\n")
```

